{
    "name": "Default",
    "slug": "default",
    "version": "1.0.0",
    "description": "A clean, modern default theme for the Web CMS. Zero external dependencies — pure CSS with responsive design, dark mode support, and polished typography.",
    "author": "Web CMS",
    "screenshot": "screenshot.png",
    "supports": [
        "pages",
        "posts",
        "menus"
    ],
    "form_placeholders": [
        {
            "key": "contact_form",
            "label": "Contact Form",
            "description": "Form displayed on the main contact sections."
        }
    ],
    "page_templates": {
        "default": {
            "label": "Default",
            "description": "Standard page with flexible block content",
            "blocks": []
        },
        "home": {
            "label": "Homepage",
            "description": "Main landing page with hero, features, and CTA",
            "blocks": [
                {"name": "hero_title", "type": "text", "label": "Hero Title", "default": "Welcome"},
                {"name": "hero_subtitle", "type": "textarea", "label": "Hero Subtitle", "default": "Build something amazing with your new CMS."},
                {"name": "hero_image", "type": "media", "label": "Hero Image", "default": ""}
            ]
        }
    },
    "seed_pages": [
        {
            "title": "Home",
            "slug": "home",
            "template": "home",
            "status": "published",
            "menu_order": 0
        },
        {
            "title": "About",
            "slug": "about",
            "template": "default",
            "status": "draft",
            "menu_order": 1
        },
        {
            "title": "Contact",
            "slug": "contact",
            "template": "default",
            "status": "draft",
            "menu_order": 2
        }
    ],
    "archive_settings": {
        "per_page": 12,
        "layout": "grid",
        "show_sidebar": true,
        "show_excerpt": true,
        "show_author": true,
        "show_date": true,
        "excerpt_length": 150
    }
}
