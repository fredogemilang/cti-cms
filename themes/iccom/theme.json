{
    "name": "iCCom",
    "slug": "iccom",
    "version": "1.0.0",
    "description": "Modern theme for Indonesia Cloud Community",
    "author": "Alfredo Gemilang",
    "screenshot": "screenshot.png",
    "supports": [
        "pages",
        "posts",
        "events",
        "membership",
        "menus",
        "widgets"
    ],
    "page_templates": {
        "default": {
            "label": "Default",
            "description": "Standard page with flexible block content",
            "blocks": []
        },
        "home": {
            "label": "Homepage",
            "description": "Main landing page",
            "blocks": [
                {"name": "hero_title",                "type": "text",     "label": "Hero Title",               "default": "iCCom"},
                {"name": "hero_subtitle",             "type": "text",     "label": "Hero Subtitle",            "default": "Indonesia Cloud Community"},
                {"name": "hero_description",          "type": "textarea", "label": "Hero Description",         "default": "Join us to level up your skills in becoming cloud engineer, and take a step forward to improve the development of cloud in Indonesia."},
                {"name": "hero_image",                "type": "media",    "label": "Hero Image",               "default": ""},
                {"name": "who_are_we_title",          "type": "text",     "label": "Who Are We Title",         "default": "Who Are We?"},
                {"name": "who_are_we_description",    "type": "wysiwyg",  "label": "Who Are We Content",       "default": "<p><strong>iCCom</strong>, or <strong>Indonesia Cloud Community</strong>, is a community for people who are enthusiastic about the development of cloud technology. We are a non-profit organization that seeks to contribute to the growth of Indonesia's cloud expert resources. We welcome all cloud enthusiasts, from newbies to professionals.</p>"},
                {"name": "who_are_we_image",          "type": "media",    "label": "Who Are We Image",         "default": ""},
                {"name": "iccom_core_value_title",    "type": "text",     "label": "Our Missions Title",       "default": "Our Missions"},
                {"name": "iccom_core_value_loop",     "type": "repeater", "label": "Missions List",            "default": "[]", "options": {"min_items": 0, "max_items": 20, "button_label": "Add Mission"}},
                {"name": "missions_image",            "type": "media",    "label": "Missions Image",           "default": ""},
                {"name": "counter_member",            "type": "number",   "label": "Member Count",             "default": 50000},
                {"name": "counter_title",             "type": "text",     "label": "Counter Title",            "default": "Have Joined to Be a Part of iCCom"},
                {"name": "testimonal_title",          "type": "text",     "label": "Testimonials Title",       "default": "What Our Members Say"},
                {"name": "talent_referral_title",     "type": "text",     "label": "CTA Title",                "default": "Join us for FREE!"},
                {"name": "talent_referral_description","type": "textarea","label": "CTA Description",           "default": "Enjoy all of our exclusive community activities!"},
                {"name": "our_partners_title",        "type": "text",     "label": "Partners Title",           "default": "Our Partners"}
            ]
        },
        "partner": {
            "label": "Partner Page",
            "description": "Partnership inquiry page",
            "blocks": [
                {"name": "hero_title",       "type": "text",     "label": "Hero Title",       "default": "Partner with iCCom"},
                {"name": "hero_description", "type": "textarea", "label": "Hero Description", "default": "Join forces with Indonesia's largest cloud community. Lets collaborate to nurture talent and drive innovation."},
                {"name": "hero_image",       "type": "media",    "label": "Hero Image",       "default": ""}
            ]
        }
    }
}
