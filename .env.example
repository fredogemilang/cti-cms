# ============================================================================
# Application
# ============================================================================
APP_NAME="My CMS"
APP_ENV=local                    # local | staging | production
APP_KEY=                         # Run: php artisan key:generate
APP_DEBUG=true                   # SET TO false IN PRODUCTION
APP_URL=http://localhost

# Admin panel path (change to obfuscate, e.g. `manage`, `backend`)
ADMIN_PATH=ctrlpanel

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ============================================================================
# Logging
# ============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================================
# Database
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=web_cms
DB_USERNAME=root
DB_PASSWORD=

# ============================================================================
# Session
# ============================================================================
SESSION_DRIVER=file              # file (dev) | redis | database (production)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local            # local (dev) | s3 (production)

# ============================================================================
# Queue
# ============================================================================
# database = good for low/mid traffic (run `php artisan queue:work`)
# redis    = recommended for production
# sync     = synchronous (dev/testing only)
QUEUE_CONNECTION=database

# ============================================================================
# Cache
# ============================================================================
CACHE_STORE=database             # database | redis (recommended for production)

# ============================================================================
# Redis (optional — recommended for cache + session + queue in production)
# ============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================================
# Mail
# ============================================================================
# Drivers: log (dev) | smtp | brevo (API — configure in Admin → Settings)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- SMTP Example (Brevo) ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-brevo-account-email
# MAIL_PASSWORD=your-brevo-smtp-key

# --- Brevo API (for hosts that block SMTP) ---
# MAIL_MAILER=brevo

# ============================================================================
# CAPTCHA (optional — configure in Admin → Settings → Forms)
# ============================================================================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================================
# S3 / Cloud Storage (optional)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# QUICK START
# ============================================================================
# 1. Copy this file to .env
# 2. php artisan key:generate
# 3. Create a MySQL database matching DB_DATABASE above
# 4. php artisan cms:install          ← interactive setup wizard
# 5. php artisan serve
#
# PRODUCTION CHECKLIST:
#   [ ] APP_ENV=production
#   [ ] APP_DEBUG=false
#   [ ] APP_URL=https://your-domain.com
#   [ ] Strong DB_PASSWORD
#   [ ] SESSION_DRIVER=redis (or database)
#   [ ] CACHE_STORE=redis
#   [ ] Supervisor running `php artisan queue:work`
#   [ ] Cron running `php artisan schedule:run` every minute
#   [ ] php artisan storage:link
#   [ ] php artisan config:cache && route:cache && view:cache
#   [ ] HTTPS enforced at web server level
