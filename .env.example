# ============================================================================
# Application
# ============================================================================
APP_NAME=Laravel
APP_ENV=local                    # local | staging | production
APP_KEY=                         # `php artisan key:generate` — keep secret; rotating invalidates sessions/encrypted data
APP_DEBUG=true                   # SET TO false IN PRODUCTION (leaks stack traces otherwise)
APP_URL=http://localhost

# Admin panel path (`/{ADMIN_PATH}` — change to e.g. `cms` to obfuscate)
ADMIN_PATH=admin

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=web-cms
DB_USERNAME=root
DB_PASSWORD=

# ============================================================================
# Session
# ============================================================================
SESSION_DRIVER=file              # file (dev) | redis | database (production)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false            # true if storing sensitive data in session
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local            # local (dev) | s3 (production with AWS_* below)

# ============================================================================
# Queue
# ============================================================================
# database = good for low/mid traffic, run `php artisan queue:work` as supervisor
# redis    = recommended for production high-traffic
# sync     = synchronous (jobs run inline — only for tests/local dev)
QUEUE_CONNECTION=database

# ============================================================================
# Cache
# ============================================================================
# database = fine for single server; redis recommended for multi-server / high traffic
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ============================================================================
# Redis (recommended for cache + session + queue in production)
# ============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================================
# Mail
# ============================================================================
# Driver options:
#   log       = write to storage/logs/laravel.log (dev/staging without SMTP)
#   smtp      = use MAIL_HOST/PORT/USERNAME/PASSWORD below (Brevo SMTP, Mailgun, SES, etc.)
#   brevo     = use Brevo API — configure via Admin → Settings → Brevo (preferred when SMTP is blocked)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Production example (Brevo SMTP) ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-brevo-account-email
# MAIL_PASSWORD=your-brevo-smtp-key   # from app.brevo.com → SMTP & API → SMTP

# --- Production example (Brevo API — for hosts that block SMTP) ---
# MAIL_MAILER=brevo
# (then configure API key + sender in Admin → Settings → Brevo)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ===========================================
# CAPTCHA Configuration (Form Spam Protection)
# ===========================================

# Google reCAPTCHA (v2 or v3)
# Get keys at: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Cloudflare Turnstile
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
#   [ ] APP_ENV=production
#   [ ] APP_DEBUG=false
#   [ ] APP_URL=https://your-domain.com
#   [ ] APP_KEY set (php artisan key:generate)
#   [ ] DB credentials configured + DB_PASSWORD strong
#   [ ] SESSION_DRIVER=redis (or database) + SESSION_DOMAIN set
#   [ ] CACHE_STORE=redis (recommended)
#   [ ] QUEUE_CONNECTION=redis (or keep database)
#   [ ] Supervisor running `php artisan queue:work` (otherwise queued mail won't send)
#   [ ] Cron running `php artisan schedule:run` every minute (otherwise activity prune / cache TTL refresh won't fire)
#   [ ] `php artisan storage:link` executed once (creates public/storage symlink)
#   [ ] `php artisan config:cache && route:cache && view:cache` AFTER all env config locked in
#   [ ] HTTPS forced at the web-server layer (NGINX/Apache)
#   [ ] gzip/brotli enabled at web-server layer (or set pageopt_gzip_enabled if not)
#   [ ] Storage permissions: storage/ and bootstrap/cache/ writable by web user
#   [ ] .env file not readable by web (chmod 600, owned by deploy user)
#   [ ] Backup strategy for DB + storage/app/public
